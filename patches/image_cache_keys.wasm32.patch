 #include <algorithm>
 #include <cctype>
+#include <cstdint>
 #include <cmath>
 #include <cstdio>
 #include <cstring>
@@ -231,14 +232,29 @@ static void image_foreach_cache(ID *id,
   function_callback(id, &key, reinterpret_cast<void **>(&image->rr), 0, user_data);
 
